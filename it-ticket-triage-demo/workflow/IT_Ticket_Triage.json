      "webhookId": "e9f04b0f-f538-4904-958b-caafe30f6356"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Subject: {{ $json['Subject'] }}\nDescription: {{ $json['Description'] }}",
        "options": {
          "systemMessage": "You are an IT support ticket classifier. Given a ticket subject and \ndescription, output ONLY valid JSON with these fields:\n{\n  \"category\": \"access_request\" | \"password_reset\" | \"software_issue\" | \"hardware_issue\" | \"network_issue\" | \"other\",\n  \"severity\": \"low\" | \"medium\" | \"high\",\n  \"confidence\": 0.0-1.0,\n  \"reasoning\": \"one sentence explanation\"\n}\n\nSeverity guidelines:\n- low: routine, self-service requests with no urgency and single-user impact (e.g. password resets, standard access requests, general how-to questions, non-urgent requests explicitly marked \"not urgent\")\n- medium: issues affecting productivity but not blocking critical work, ambiguous or incomplete requests, or requests with unclear urgency\n- high: production outages, security incidents, multi-user or system-wide impact, or requests explicitly marked urgent/critical\n\nWhen a user explicitly states a request is \"not urgent\" or \"whenever possible,\" weigh this strongly toward \"low\" severity even if the category (e.g. password reset) might otherwise seem sensitive.\n\nNo preamble, no markdown, JSON only."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -464,
        -80
      ],
      "id": "5d93f0e6-8681-40f4-9c7c-9bd17fc92a45",
      "name": "Classifier Agent"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "fcb44534-b323-41f8-9186-8ca357475fe0",
              "name": "category",
              "value": "={{ JSON.parse($json.output).category }}",
              "type": "string"
            },
            {
              "id": "d137390a-ac40-44a1-be6c-87e1f043184e",
              "name": "severity",
              "value": "={{ JSON.parse($json.output).severity }}",
              "type": "string"
            },
            {
              "id": "76de01bc-d2a2-4dfd-bcc1-379b2ddf3c5b",
              "name": "confidence",
              "value": "={{ JSON.parse($json.output).confidence }}",
              "type": "string"
            },
            {
              "id": "539c08ee-dfd0-4eb0-af5d-8dc773b71130",
              "name": "reasoning",
              "value": "={{ JSON.parse($json.output).reasoning }}",
              "type": "string"
            }
          ]
        },
        "options": {}
