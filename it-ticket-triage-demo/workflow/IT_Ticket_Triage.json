          ]
        },
        "options": {
          "customCss": "body {\n  font-family: 'Segoe UI', sans-serif;\n  background-color: #f7f7f9;\n}\n\n.n8n-form-header h1 {\n  color: #2b2b2b;\n}\n\nbutton[type=\"submit\"] {\n  background-color: #FF6B4A !important;\n  border-radius: 6px !important;\n  font-weight: 600;\n}\n\n.n8n-form-input, .n8n-form-textarea {\n  border-radius: 6px !important;\n}"
